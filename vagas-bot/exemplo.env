# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_USER_ID=

# LLM (Fase 1: placeholder; usado a partir da Fase 4)
LLM_PROVIDER=openai
OPENAI_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://vagas:vagas@postgres:5432/vagas

# Redis
REDIS_URL=redis://redis:6379/0

# Cripto: gere com `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
FERNET_KEY=

# Operação
LOG_LEVEL=INFO
ENV=dev

# SMTP opcional — candidatura por e-mail (Gmail: ative 2FA e crie "senha de app")
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu.email@gmail.com
# SMTP_PASSWORD=
# SMTP_FROM_NAME=Seu Nome
