# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_USER_ID=

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=

# Database
DATABASE_URL=postgresql+psycopg://vagas:vagas@postgres:5432/vagas

# Redis
REDIS_URL=redis://redis:6379/0

# Cripto: gere com `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"`
FERNET_KEY=

# Operação
LOG_LEVEL=INFO
ENV=dev
DAILY_APPLY_LIMIT=20

# SMTP opcional — candidatura por e-mail (Gmail: ative 2FA e crie "senha de app")
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu.email@gmail.com
# SMTP_PASSWORD=
# SMTP_FROM_NAME=Seu Nome

# LangSmith opcional — observabilidade do agente (free tier: 5k traces/mês)
# https://smith.langchain.com → Settings → API Keys
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_...
# LANGCHAIN_PROJECT=vagas-bot
